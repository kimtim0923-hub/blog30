# ─────────────────────────────────────────────────────────
# AI있다 TAAFT Tracker — 환경변수 예시 파일
# 이 파일을 복사해서 apps/scripts/.env 로 만든 후 값을 채우세요
# ─────────────────────────────────────────────────────────

# Google Sheets
GOOGLE_CREDENTIALS_JSON=./credentials.json
SPREADSHEET_ID=your_spreadsheet_id_here

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Tistory (카카오 계정)
TISTORY_ID=your_kakao_email@gmail.com
TISTORY_PW=your_kakao_password
TISTORY_BLOG_NAME=your-blog.tistory.com
